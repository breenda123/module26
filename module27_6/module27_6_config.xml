      <rdf:Description dc:date="2024-12-16 11:37:21 PM" dc:source="Camtasia,9.0.4,enu" dc:title="module27_6" tscDM:firstFrame="module27_6_First_Frame.png" tscDM:originId="67823403-5526-4B23-8647-20BF45EAEF59" tscDM:project="module27_6">
